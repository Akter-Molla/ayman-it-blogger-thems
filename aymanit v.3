<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE html>
<html b:css='false' b:defaultwidgetcss='false' b:responsive='true' lang='bn' xmlns='http://www.w3.org/1999/xhtml' xmlns:b='http://www.google.com/2005/gml/b' xmlns:data='http://www.google.com/2005/gml/data' xmlns:expr='http://www.google.com/2005/gml/expr'>
<head>
    <meta charset='UTF-8'/>
    <meta content='width=device-width, initial-scale=1.0' name='viewport'/>
    <meta content='blogger' name='generator'/>
    <meta content='text/html; charset=UTF-8' http-equiv='Content-Type'/>
    <meta content='Ayman IT &amp; Online Services - Professional Digital Services in Bangladesh' name='description'/>
    <meta content='Ayman IT, Digital Services, Online Application, IT Training, Bangladesh' name='keywords'/>
    <title><data:blog.pageTitle/></title>
    <b:if cond='data:blog.metaDescription'>
        <meta expr:content='data:blog.metaDescription' name='description'/>
    </b:if>
    
    <b:skin><![CDATA[
    @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Hind+Siliguri:wght@400;500;600;700&display=swap');

    :root {
        --primary: #d4af37;
        --primary-dark: #b8960c;
        --primary-glow: rgba(212, 175, 55, 0.25);
        --bg-dark: #0a0e14;
        --bg-darker: #05070a;
        --bg-card: rgba(18, 24, 32, 0.92);
        --text-white: #ffffff;
        --text-muted: #a0abb8;
        --border: rgba(212, 175, 55, 0.25);
        --border-light: rgba(255,255,255,0.06);
        --gradient-gold: linear-gradient(135deg, #d4af37 0%, #f5e47a 50%, #d4af37 100%);
        --shadow-elevation: 0 20px 35px -12px rgba(0,0,0,0.5);
        --shadow-glow: 0 8px 20px rgba(212,175,55,0.2);
        --transition-smooth: all 0.4s cubic-bezier(0.2, 0.9, 0.4, 1.1);
        --ad-bg: #1a1f2a;
        --ad-border: rgba(212, 175, 55, 0.3);
    }

    * { margin:0; padding:0; box-sizing: border-box; scroll-behavior: smooth; }
    body {
        font-family: 'Plus Jakarta Sans', 'Hind Siliguri', sans-serif;
        background-color: var(--bg-dark);
        color: var(--text-white);
        line-height: 1.65;
        overflow-x: hidden;
    }
    a { text-decoration: none; color: inherit; }
    img { max-width: 100%; display: block; }

    /* AdSense Safe Zones */
    .adsense-container {
        background: var(--ad-bg);
        border-radius: 16px;
        padding: 20px;
        margin: 20px 0;
        text-align: center;
        border: 1px solid var(--ad-border);
        min-height: 100px;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .adsense-label {
        font-size: 12px;
        color: var(--text-muted);
        margin-bottom: 10px;
        text-transform: uppercase;
        letter-spacing: 1px;
    }
    .ad-placeholder {
        background: rgba(255,255,255,0.05);
        border-radius: 12px;
        padding: 20px;
        color: var(--text-muted);
        font-size: 12px;
    }

    /* Layout utils */
    .container { max-width: 1280px; margin: 0 auto; padding: 0 24px; }
    .section-padding { padding: 100px 0; position: relative; }
    .section-header { text-align: center; margin-bottom: 60px; }
    .section-header h2 {
        font-size: 2.8rem;
        font-weight: 800;
        background: var(--gradient-gold);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
        letter-spacing: -0.02em;
    }
    .section-header p {
        color: var(--text-muted);
        font-size: 1.2rem;
        max-width: 620px;
        margin: 16px auto 0;
    }

    /* buttons */
    .btn-primary {
        background: var(--gradient-gold);
        color: #0a0e14;
        font-weight: 800;
        padding: 14px 36px;
        border-radius: 60px;
        display: inline-block;
        transition: var(--transition-smooth);
        box-shadow: var(--shadow-glow);
        border: none;
        font-size: 1rem;
        letter-spacing: 0.3px;
        cursor: pointer;
    }
    .btn-primary:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 28px rgba(212,175,55,0.4);
        background: linear-gradient(135deg, #e5c242, #fcf6ba);
    }
    .btn-outline {
        background: transparent;
        border: 2px solid var(--primary);
        color: var(--primary);
        padding: 12px 34px;
        border-radius: 60px;
        font-weight: 700;
        transition: var(--transition-smooth);
        display: inline-block;
    }
    .btn-outline:hover {
        background: var(--primary);
        color: #0a0e14;
        transform: translateY(-3px);
    }

    /* HEADER */
    header {
        position: fixed;
        top: 0;
        width: 100%;
        z-index: 1100;
        background: rgba(10, 14, 20, 0.92);
        backdrop-filter: blur(16px);
        border-bottom: 1px solid var(--border);
        padding: 0 5%;
        display: flex;
        justify-content: space-between;
        align-items: center;
        height: 82px;
        transition: 0.3s;
    }
    .logo-area {
        display: flex;
        align-items: center;
        gap: 12px;
        text-decoration: none;
    }
    .logo-icon {
        width: 48px;
        height: 48px;
        background: var(--gradient-gold);
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 800;
        font-size: 26px;
        color: #111;
        box-shadow: 0 6px 14px rgba(212,175,55,0.3);
        transition: transform 0.25s;
    }
    .logo-area:hover .logo-icon { transform: scale(1.05) rotate(-4deg); }
    .logo-text {
        font-size: 1.7rem;
        font-weight: 800;
        background: var(--gradient-gold);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
        letter-spacing: -0.3px;
        margin: 0;
    }
    .header-image-logo {
        max-height: 55px;
        width: auto;
        transition: transform 0.25s;
    }
    .logo-area:hover .header-image-logo { transform: scale(1.05); }
    
    nav ul {
        display: flex;
        gap: 2rem;
        list-style: none;
    }
    nav li a {
        font-weight: 600;
        font-size: 1rem;
        color: #e2e8f0;
        transition: 0.2s;
        position: relative;
        padding-bottom: 6px;
    }
    nav li a:hover { color: var(--primary); }
    nav li a::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 0;
        width: 0%;
        height: 2px;
        background: var(--primary);
        transition: 0.25s;
    }
    nav li a:hover::after { width: 100%; }
    @media (max-width: 800px) { nav { display: none; } }

    /* breaking news */
    .news-ticker-wrapper {
        background: #06090e;
        border-bottom: 1px solid var(--primary);
        padding: 10px 5%;
        margin-top: 82px;
        position: relative;
        z-index: 1090;
    }
    .ticker-container {
        max-width: 1280px;
        margin: 0 auto;
        display: flex;
        align-items: center;
        gap: 24px;
    }
    .ticker-label {
        background: var(--primary);
        color: #000;
        font-weight: 800;
        padding: 5px 18px;
        border-radius: 40px;
        font-size: 0.8rem;
        letter-spacing: 0.5px;
        white-space: nowrap;
    }
    .ticker-content { overflow: hidden; flex: 1; }
    .ticker-marquee {
        display: flex;
        gap: 48px;
        animation: scrollTicker 28s linear infinite;
        white-space: nowrap;
    }
    .ticker-item { display: inline-flex; align-items: center; gap: 10px; font-size: 0.85rem; font-weight: 500; }
    .ticker-item .dot { width: 6px; height: 6px; background: var(--primary); border-radius: 50%; }
    .ticker-item a { color: #cbd5e6; transition: 0.2s; }
    .ticker-item a:hover { color: var(--primary); }
    @keyframes scrollTicker { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }

    /* Hero */
    .hero {
        min-height: 92vh;
        display: flex;
        align-items: center;
        position: relative;
        padding: 100px 5%;
        background: radial-gradient(circle at 30% 10%, rgba(26,32,44,0.85), #0a0e14 85%);
    }
    .hero-content { max-width: 780px; margin: 0 auto; text-align: center; z-index: 2; }
    .badge {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        background: rgba(212,175,55,0.12);
        border: 1px solid var(--border);
        padding: 8px 24px;
        border-radius: 60px;
        font-size: 0.85rem;
        font-weight: 600;
        margin-bottom: 28px;
        backdrop-filter: blur(4px);
    }
    .badge span { width: 8px; height: 8px; background: var(--primary); border-radius: 50%; animation: pulse 1.8s infinite; }
    .hero h1 {
        font-size: clamp(2.8rem, 7vw, 5rem);
        font-weight: 800;
        line-height: 1.2;
        margin-bottom: 24px;
    }
    .hero h1 span { background: var(--gradient-gold); -webkit-background-clip: text; background-clip: text; color: transparent; }
    .hero p { font-size: 1.2rem; color: var(--text-muted); margin-bottom: 36px; max-width: 560px; margin-left: auto; margin-right: auto; }
    .hero-buttons { display: flex; gap: 20px; justify-content: center; flex-wrap: wrap; }
    @keyframes pulse { 0% { opacity: 0.6; transform: scale(1); } 50% { opacity: 1; transform: scale(1.2); } 100% { opacity: 0.6; transform: scale(1); } }

    /* Blog Grid */
    .blog-section-enhanced {
        background: linear-gradient(180deg, #0a0e14 0%, #0c1119 100%);
    }
    .blog-grid-enhanced {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
        gap: 35px;
        margin-bottom: 50px;
    }
    .post-card-enhanced {
        background: var(--bg-card);
        border-radius: 32px;
        overflow: hidden;
        border: 1px solid var(--border-light);
        transition: var(--transition-smooth);
        backdrop-filter: blur(10px);
        position: relative;
    }
    .post-card-enhanced:hover {
        transform: translateY(-12px);
        border-color: var(--primary);
        box-shadow: var(--shadow-elevation);
    }
    .post-thumb-enhanced {
        position: relative;
        height: 240px;
        overflow: hidden;
    }
    .post-thumb-enhanced img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.6s;
    }
    .post-card-enhanced:hover .post-thumb-enhanced img {
        transform: scale(1.08);
    }
    .post-category {
        position: absolute;
        top: 20px;
        left: 20px;
        background: var(--primary);
        color: #000;
        padding: 5px 15px;
        border-radius: 30px;
        font-size: 0.75rem;
        font-weight: 700;
        z-index: 2;
        box-shadow: 0 2px 8px rgba(0,0,0,0.2);
    }
    .post-info-enhanced {
        padding: 28px;
    }
    .post-meta-enhanced {
        display: flex;
        gap: 20px;
        margin-bottom: 15px;
        font-size: 0.8rem;
        color: var(--text-muted);
    }
    .post-meta-enhanced i {
        color: var(--primary);
        margin-right: 6px;
    }
    .post-info-enhanced h3 {
        font-size: 1.5rem;
        line-height: 1.4;
        margin-bottom: 15px;
    }
    .post-info-enhanced h3 a {
        color: #fff;
        transition: 0.2s;
    }
    .post-info-enhanced h3 a:hover {
        color: var(--primary);
    }
    .post-excerpt {
        color: var(--text-muted);
        line-height: 1.6;
        margin-bottom: 20px;
        font-size: 0.95rem;
    }
    .read-more-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: var(--primary);
        font-weight: 700;
        transition: 0.2s;
    }
    .read-more-btn:hover {
        gap: 12px;
        color: #fff;
    }
    .blog-pagination {
        display: flex;
        justify-content: center;
        gap: 15px;
        margin-top: 50px;
    }
    .blog-pagination a, .blog-pagination span {
        padding: 12px 20px;
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 50px;
        transition: 0.2s;
        font-weight: 600;
    }
    .blog-pagination a:hover, .blog-pagination .current-page {
        background: var(--primary);
        color: #000;
        border-color: var(--primary);
    }

    /* LAYOUT WITH WIDGET SIDEBARS */
    .page-wrapper {
        max-width: 1400px;
        margin: 120px auto 70px;
        padding: 0 24px;
    }
    .content-with-sidebars {
        display: grid;
        grid-template-columns: 300px 1fr 340px;
        gap: 40px;
    }
    
    /* Sidebar Widget Areas */
    .left-sidebar-area, .right-sidebar-area {
        background: var(--bg-card);
        border-radius: 28px;
        border: 1px solid var(--border);
        backdrop-filter: blur(10px);
        overflow: hidden;
        align-self: start;
    }
    .sidebar-widget {
        padding: 24px;
        border-bottom: 1px solid var(--border-light);
    }
    .sidebar-widget:last-child {
        border-bottom: none;
    }
    .sidebar-widget h2, .sidebar-widget h3 {
        font-size: 1.3rem;
        color: var(--primary);
        margin-bottom: 20px;
        padding-bottom: 12px;
        border-bottom: 2px solid var(--border);
        display: inline-block;
    }
    .sidebar-widget ul {
        list-style: none;
    }
    .sidebar-widget ul li {
        margin-bottom: 12px;
    }
    .sidebar-widget ul li a {
        color: var(--text-muted);
        transition: 0.2s;
        display: block;
        padding: 6px 0;
    }
    .sidebar-widget ul li a:hover {
        color: var(--primary);
        padding-left: 8px;
    }
    
    /* Popular Posts Styling */
    .popular-posts ul li {
        display: flex;
        gap: 12px;
        margin-bottom: 15px;
        align-items: center;
    }
    .popular-posts .item-thumbnail {
        width: 60px;
        height: 60px;
        border-radius: 12px;
        overflow: hidden;
        flex-shrink: 0;
    }
    .popular-posts .item-thumbnail img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }
    .popular-posts .item-title {
        font-size: 0.85rem;
        line-height: 1.3;
    }
    .popular-posts .item-title a {
        color: #fff;
    }
    .popular-posts .item-title a:hover {
        color: var(--primary);
    }
    
    /* Featured Post Styling */
    .featured-post .featured-thumb {
        border-radius: 20px;
        overflow: hidden;
        margin-bottom: 15px;
    }
    .featured-post .featured-thumb img {
        width: 100%;
        height: auto;
    }
    .featured-post h4 a {
        color: #fff;
        font-size: 1.1rem;
    }
    
    /* Contact Info Styling */
    .contact-info p {
        margin-bottom: 10px;
        color: var(--text-muted);
    }
    .contact-info i {
        color: var(--primary);
        width: 25px;
        margin-right: 8px;
    }
    
    /* Main Content Area */
    .single-post-card {
        background: var(--bg-card);
        border-radius: 48px;
        overflow: hidden;
        border: 1px solid var(--border);
        backdrop-filter: blur(10px);
        margin-bottom: 40px;
    }
    .single-post-header {
        padding: 50px 50px 30px;
        text-align: center;
        border-bottom: 1px solid var(--border-light);
    }
    .single-post-header h1 {
        font-size: 2.8rem;
        margin: 20px 0 20px;
        line-height: 1.3;
    }
    .single-post-meta {
        display: flex;
        justify-content: center;
        gap: 30px;
        flex-wrap: wrap;
        color: var(--text-muted);
        font-size: 0.9rem;
    }
    .single-post-meta i {
        color: var(--primary);
        margin-right: 8px;
    }
    .single-featured-image {
        margin: 30px 50px;
        border-radius: 32px;
        overflow: hidden;
        border: 1px solid var(--border);
        box-shadow: var(--shadow-elevation);
    }
    .single-post-body {
        padding: 30px 50px 50px;
        color: #e2edf7;
        font-size: 1.05rem;
        line-height: 1.85;
    }
    .single-post-body p {
        margin-bottom: 1.5em;
    }
    .single-post-body h2, .single-post-body h3 {
        color: var(--primary);
        margin: 1.5em 0 0.8em;
    }
    .single-post-body img {
        max-width: 100%;
        height: auto;
        border-radius: 20px;
        margin: 20px 0;
    }
    .single-post-body blockquote {
        border-left: 4px solid var(--primary);
        background: rgba(212,175,55,0.05);
        padding: 20px 30px;
        margin: 25px 0;
        border-radius: 20px;
        font-style: italic;
    }
    .single-post-footer {
        padding: 30px 50px 50px;
        border-top: 1px solid var(--border-light);
    }
    .post-labels {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        margin-bottom: 30px;
    }
    .post-labels a {
        background: rgba(212,175,55,0.12);
        padding: 6px 18px;
        border-radius: 50px;
        font-size: 0.8rem;
        border: 1px solid var(--border);
        transition: 0.2s;
    }
    .post-labels a:hover {
        background: var(--primary);
        color: #000;
    }
    .post-share-area {
        display: flex;
        align-items: center;
        gap: 20px;
        flex-wrap: wrap;
        margin-bottom: 40px;
        padding-bottom: 30px;
        border-bottom: 1px solid var(--border-light);
    }
    .share-buttons {
        display: flex;
        gap: 12px;
    }
    .share-btn {
        width: 44px;
        height: 44px;
        background: rgba(255,255,255,0.05);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: 0.2s;
    }
    .share-btn:hover {
        background: var(--primary);
        color: #000;
        transform: translateY(-3px);
    }
    .post-author-card {
        display: flex;
        gap: 25px;
        background: rgba(0,0,0,0.4);
        border-radius: 32px;
        padding: 30px;
        margin: 30px 0;
        border: 1px solid var(--border-light);
    }
    .author-avatar {
        width: 90px;
        height: 90px;
        border-radius: 50%;
        border: 3px solid var(--primary);
        overflow: hidden;
        flex-shrink: 0;
    }
    .author-avatar img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }
    .author-info h4 {
        font-size: 1.3rem;
        margin-bottom: 10px;
        color: #fff;
    }
    .post-navigation-area {
        display: flex;
        justify-content: space-between;
        gap: 20px;
        margin: 40px 0;
    }
    .nav-post {
        flex: 1;
        background: rgba(255,255,255,0.03);
        padding: 20px;
        border-radius: 24px;
        border: 1px solid var(--border);
        transition: 0.2s;
    }
    .nav-post:hover {
        border-color: var(--primary);
        background: rgba(212,175,55,0.05);
    }
    .nav-post .nav-label {
        color: var(--primary);
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        display: block;
        margin-bottom: 8px;
    }

    /* Comments Section */
    .comments-wrapper {
        background: var(--bg-card);
        border-radius: 44px;
        padding: 45px;
        border: 1px solid var(--border);
    }
    .comments-wrapper h3 {
        font-size: 1.8rem;
        color: var(--primary);
        margin-bottom: 30px;
        text-align: center;
    }
    .comment {
        background: rgba(255,255,255,0.03);
        padding: 25px;
        border-radius: 24px;
        margin-bottom: 20px;
        border: 1px solid var(--border-light);
    }
    .comment-author {
        font-weight: 700;
        color: var(--primary);
        margin-bottom: 8px;
    }
    .comment-date {
        font-size: 0.75rem;
        color: var(--text-muted);
        margin-bottom: 12px;
    }

    @media (max-width: 1100px) {
        .content-with-sidebars {
            grid-template-columns: 1fr;
            gap: 30px;
        }
    }
    @media (max-width: 780px) {
        .blog-grid-enhanced { grid-template-columns: 1fr; }
        .single-post-header { padding: 30px 25px; }
        .single-post-header h1 { font-size: 2rem; }
        .single-post-body { padding: 20px 25px; }
        .single-featured-image { margin: 20px 25px; }
        .post-author-card { flex-direction: column; text-align: center; align-items: center; }
        .comments-wrapper { padding: 25px; }
        .section-padding { padding: 60px 0; }
    }
    ]]></b:skin>
</head>
<body>
    <!-- Ticker Section -->
    <b:section class='ticker-section' id='ticker-section' maxwidgets='1' showaddelement='yes'>
      <b:widget id='HTML99' locked='false' title='News Ticker' type='HTML' version='2' visible='true'>
        <b:widget-settings>
          <b:widget-setting name='content'><![CDATA[<div class='news-ticker-wrapper'>
                        <div class='ticker-container'>
                            <span class='ticker-label'>সাম্প্রতিক</span>
                            <div class='ticker-content'>
                                <div class='ticker-marquee'>
                                    <span class='ticker-item'><span class='dot'></span><a href='#'>🚀 নতুন অনলাইন আবেদন সেবা চালু হয়েছে</a></span>
                                    <span class='ticker-item'><span class='dot'></span><a href='#'>📢 ২৬শে মার্চ সকল শাখা বন্ধ থাকবে</a></span>
                                    <span class='ticker-item'><span class='dot'></span><a href='#'>💻 ফ্রি আইটি প্রশিক্ষণের রেজিস্ট্রেশন চলছে</a></span>
                                    <span class='ticker-item'><span class='dot'></span><a href='#'>🎉 সোনালী সপ্তাহে বিশেষ ছাড়!</a></span>
                                </div>
                            </div>
                        </div>
                    </div>]]></b:widget-setting>
        </b:widget-settings>
        <b:includable id='main'>
